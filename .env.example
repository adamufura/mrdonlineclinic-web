# Dev: root-relative API base keeps requests on the Vite origin (localhost or 127.0.0.1); /api and /socket.io proxy to the backend (vite.config.ts).
VITE_API_BASE_URL=/api/v1
VITE_SOCKET_URL=http://127.0.0.1:5173
# Used for returnUrl / email links in dev (backend CLIENT_URL should match)
VITE_APP_URL=http://127.0.0.1:5173
